{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Serve site on localhost",
            "type": "shell",
            "command": "py",
            "args": [
                "-m",
                "http.server",
                "5500"
            ],
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "reveal": "never",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Serving HTTP on .* port 5500"
                }
            }
        }
    ]
}
